[
  {{- $bilSider := where .Site.RegularPages "Section" "biler" -}}
  {{- range $index, $page := $bilSider -}}
  {{- if $index -}},{{- end -}}
  {
    "title": {{ $page.Title | jsonify }},
    "permalink": {{ $page.Permalink | jsonify }},
    "slug": {{ $page.File.TranslationBaseName | jsonify }},
    "merke": {{ $page.Params.brand | jsonify }},
    "modell": {{ $page.Params.modeldescription | jsonify }},
    "pris": {{ $page.Params.price0 | jsonify }},
    "bilde": {{ $page.Params.mainImageUrl | jsonify }},
    "fuel": {{ $page.Params.fuel | jsonify }},
    "gear": {{ $page.Params.gear | jsonify }},
    "drive": {{ $page.Params.drive | jsonify }},
    "range": {{ $page.Params.range | jsonify }},
    "performance": {{ $page.Params.performance | jsonify }},
    "doors": {{ $page.Params.doors | jsonify }},
    "seats": {{ $page.Params.seats | jsonify }},
    "yearmodel": {{ $page.Params.yearmodel | jsonify }},
    "color": {{ $page.Params.color | jsonify }},
    "interior": {{ $page.Params.interior | jsonify }},
    "charging": {{ $page.Params.charging | jsonify }},
    "capacity": {{ $page.Params.capacity | jsonify }},
    "towbar": {{ $page.Params.towbar | jsonify }},
    "interest": {{ $page.Params.interest | jsonify }}
  }
  {{- end -}}
]